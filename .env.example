# ==========================================
# LifeLink AI - Environment Configuration
# ==========================================

# Application Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# FastAPI Server Configurations
API_HOST=127.0.0.1
API_PORT=8000

# Google AI Studio API Key (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
# Default to SQLite for local development
DATABASE_URL=sqlite:///./lifelink.db

# Model Context Protocol (MCP) Server Configurations
MCP_SERVER_URL=http://localhost:8080
# If using local python-based MCP command servers
# MCP_SERVER_COMMAND=python,path/to/mcp/server.py

# Security Settings
# Run python -c "import secrets; print(secrets.token_urlsafe(32))" to generate a secure secret key
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=60
